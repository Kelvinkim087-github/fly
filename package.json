{
  "name": "STK_Mpesa",
  "version": "1.1.0",
  "author": "Kelvin Kimathi",
  "description": "An STK Push App",
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.stk.mpesa",
    "productName": "STK-Mpesa",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerFilename": "STK-Mpesa.exe"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^5.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "electron-squirrel-startup": "^1.0.0",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.8.8",
    "morgan": "^1.10.1",
    "mssql": "^12.3.1",
    "node-cache": "^5.1.2",
    "react": "^18.2.0",
    "react-data-table-component": "^7.7.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "vite": "^5.4.21"
  }
}
